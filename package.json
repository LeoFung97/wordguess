{
  "name": "chinese-semantle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "prepare:vectors": "tsx scripts/prepare-vectors.ts",
    "prepare:fasttext": "tsx scripts/prepare-vectors.ts --input=data/raw/cc.zh.300.vec.gz --words-output=data/words.json --vectors-output=data/vectors.f32 --limit=50000"
  },
  "dependencies": {
    "@next/eslint-plugin-next": "latest",
    "@tailwindcss/postcss": "latest",
    "clsx": "latest",
    "next": "latest",
    "opencc-js": "^1.3.1",
    "react": "latest",
    "react-dom": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
